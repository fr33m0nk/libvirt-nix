<!--
  libvirt domain for the NixOS dev VM on the RK3588 (Armbian) host.

  @PLACEHOLDERS@ are filled in by setup-libvirt-vm.sh (paths, bridge, firmware).

  LAYOUT: 2+2 dedicated-core split (see README "Performance tuning").
  The RK3588 is big.LITTLE: A55 (little) = host cpu0-3, A76 (big) = host cpu4-7.
  This VM gets 4 vCPUs pinned 1:1 to ISOLATED physical cores — 2 little + 2 big:
      guest vcpu0 -> cpu2 (A55)   guest vcpu2 -> cpu6 (A76)
      guest vcpu1 -> cpu3 (A55)   guest vcpu3 -> cpu7 (A76)
  The host keeps cpu0,1 (A55) + cpu4,5 (A76) for itself + QEMU's emulator/IO
  threads. Cores 2,3,6,7 are removed from the host scheduler via the kernel
  cmdline so NOTHING on the host (ZFS/NAS/docker/etc.) preempts the pinned vCPUs:
      isolcpus=managed_irq,domain,2,3,6,7 nohz_full=2,3,6,7 rcu_nocbs=2,3,6,7
  (added to /boot/armbianEnv.txt extraargs= on the host; verify /proc/cmdline and
  /sys/devices/system/cpu/isolated after reboot).

  1:1 vcpupin (each vCPU bolted to one core, never migrating between clusters) is
  what defeats the CCSIDR "Failed to put registers after init" crash that killed
  floating-vCPU setups under Lima — libvirt applies the pin during its -S (paused)
  startup, before the per-vCPU register init. Still true with 4 vCPUs.

  VERIFY the cpuset numbers against `lscpu -e` on your host (A76 ≈ 2.25 GHz). The
  guest sees a 2-cluster topology: guest cpu0,1 = A55, guest cpu2,3 = A76 — the
  guest config pins background work to 0-1 and lets interactive work reach 2,3
  (big-core "preference by exclusion", since QEMU virt passes no capacity info).
-->
<domain type="kvm">
  <name>lc-nix-libvirt</name>
  <memory unit="GiB">12</memory>
  <currentMemory unit="GiB">12</currentMemory>

  <!-- virtiofs requires shared memory (memfd). Backed by 2 MiB hugepages to cut
       TLB misses for the JVM/clojure-lsp. This PINS 12 GiB on the host, so reserve
       the pages there BEFORE start (fragmentation makes late reservation fail).
       IMPORTANT: reserve MORE than the exact guest size — QEMU needs all 6144 pages
       (12 GiB) FREE at once, but the host always has a handful in use, so a pool
       sized exactly to the guest fails ("unable to map backing store ... Cannot
       allocate memory"). Give ~256 pages of headroom:
         12 GiB / 2 MiB = 6144 pages  ->  reserve 6400 (adds hugepages=6400 to the
         host kernel cmdline in /boot/armbianEnv.txt, alongside isolcpus=...).
       Verify: grep -i huge /proc/meminfo  (HugePages_Free must be >= 6144 pre-start). -->
  <memoryBacking>
    <source type="memfd"/>
    <access mode="shared"/>
    <hugepages/>
  </memoryBacking>

  <vcpu placement="static">4</vcpu>

  <!-- One dedicated IOThread so virtio-blk completion handling runs on its own
       thread (pinned to a HOST core below) instead of stealing cycles from the
       pinned vCPU threads. -->
  <iothreads>1</iothreads>

  <cputune>
    <!-- 1:1 pin onto the ISOLATED cores: 2 A55 (little) + 2 A76 (big) -->
    <vcpupin vcpu="0" cpuset="2"/>   <!-- A55 (little) -->
    <vcpupin vcpu="1" cpuset="3"/>   <!-- A55 (little) -->
    <vcpupin vcpu="2" cpuset="6"/>   <!-- A76 (big) -->
    <vcpupin vcpu="3" cpuset="7"/>   <!-- A76 (big) -->
    <!-- QEMU's own emulator + block-IO threads live on the HOST's little cores
         (cpu0,1) — deliberately OFF the isolated vCPU cores so they can never
         steal cycles from the guest. -->
    <emulatorpin cpuset="0-1"/>
    <iothreadpin iothread="1" cpuset="0-1"/>
    <!-- Real-time (FIFO) scheduling for the A76 (big) guest vCPUs (2-3) to cut
         jitter. Now that host cores 6,7 are isolcpus'd, the cgroup-v2 blocker can
         be cleared host-side (see README "Phase 2: FIFO"): in /etc/libvirt/qemu.conf
         set user="root" + group="root" AND drop "cpu" from cgroup_controllers, then
         `systemctl restart libvirtd`. cgroup v2 forbids SCHED_FIFO for a task in a
         cpu-controlled cgroup, and QEMU needs CAP_SYS_NICE (root) to set it.
         Enable ONLY after that groundwork — otherwise `virsh start` fails with
         "Cannot set scheduler parameters ... Operation not permitted":
    <vcpusched vcpus="2-3" scheduler="fifo" priority="1"/> -->
  </cputune>

  <os>
    <type arch="aarch64" machine="virt">hvm</type>
    <!-- UEFI: AAVMF firmware (qemu-efi-aarch64). @LOADER@/@NVRAM@ filled by the
         script; the template is the Debian path. -->
    <loader readonly="yes" type="pflash">@LOADER@</loader>
    <nvram template="@NVRAM_TEMPLATE@">@NVRAM@</nvram>
    <boot dev="hd"/>
  </os>

  <features>
    <gic version="3"/>
  </features>

  <!-- -cpu host: pass the physical core through. Required for the big.LITTLE test.
       The <topology> models a 2-cluster layout so the guest scheduler gets a cluster
       scheduling domain: cluster0 = vcpu0,1 (A55), cluster1 = vcpu2,3 (A76).
       sockets×clusters×cores×threads must stay = 4 (matches <vcpu>4 + the 4 vcpupins).
       NOTE: QEMU 'virt' + host-passthrough does NOT pass ARM capacity-dmips-mhz, so
       the guest won't do capacity-aware/EAS placement — but with 1:1 pinning vcpu2,3
       report the A76 MIDR and vcpu0,1 the A55 MIDR, so the guest can still tell them
       apart; the topology gives grouping, and the guest config supplies *preference*
       by keeping background work off the big cores (see configuration.nix).
       'clusters' needs qemu ≥ 7.0 / libvirt ≥ 7.10 — if `virsh define` rejects it,
       fall back to: <topology sockets="2" cores="2" threads="1"/> -->
  <cpu mode="host-passthrough" check="none">
    <topology sockets="1" clusters="2" cores="2" threads="1"/>
  </cpu>

  <clock offset="utc"/>
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>

  <devices>
    <emulator>@EMULATOR@</emulator>

    <!-- Root disk: the qcow2 built by `nix build .#qcow`, staged + resized. -->
    <disk type="file" device="disk">
      <driver name="qemu" type="qcow2" discard="unmap" iothread="1"
              cache="none" io="native"/>
      <source file="@DISK@"/>
      <target dev="vda" bus="virtio"/>
    </disk>

    <!-- virtiofs share of secrets (ssh key, cachix token, nixos_user).
         The flake repo is cloned by the guest from GitHub at boot.
         target dir must match configuration.nix fileSystems device "nixos-secrets". -->
    <filesystem type="mount" accessmode="passthrough">
      <driver type="virtiofs"/>
      <source dir="@SECRETS@"/>
      <target dir="nixos-secrets"/>
    </filesystem>

    <!-- Networking. Default: macvtap (type='direct') onto the host NIC → the VM
         gets a real LAN IP from your router, reachable from the laptop, with NO
         host bridge needed (nothing for OpenMediaVault's network mgmt to clash
         with). Caveat: the HOST itself can't reach the VM over macvtap (kernel
         limitation) — manage it via `virsh console`; other LAN machines are fine.
         @NIC@ = the host ethernet device (filled by the script; see `ip -br link`). -->
    <interface type="direct" trustGuestRxFilters="yes">
      <source dev="@NIC@" mode="bridge"/>
      <model type="virtio"/>
      <rom enabled="no"/>   <!-- no PXE option ROM (avoids needing ipxe-qemu's efi-virtio.rom) -->
    </interface>
    <!-- Alternative A — real host bridge (host CAN also reach the VM). Create the
         bridge in the OMV web UI first (Network > Interfaces > Bridge), then replace
         the block above with:
    <interface type="bridge">
      <source bridge="br0"/>
      <model type="virtio"/>
    </interface>
    -->
    <!-- Alternative B — libvirt NAT (private 192.168.122.x; reach via host or a
         portForward). Needs `virsh net-start default`. Replace the block above with:
    <interface type="network">
      <source network="default"/>
      <model type="virtio"/>
    </interface>
    -->

    <!-- serial console for `virsh console` -->
    <serial type="pty"><target type="system-serial" port="0"/></serial>
    <console type="pty"><target type="serial" port="0"/></console>

    <!-- qemu-guest-agent channel (pairs with services.qemuGuest in the guest) -->
    <channel type="unix">
      <target type="virtio" name="org.qemu.guest_agent.0"/>
    </channel>

    <rng model="virtio"><backend model="random">/dev/urandom</backend></rng>

    <!-- virtio memory balloon: host can reclaim unused guest RAM.
         Check with: virsh dommemstat lc-nix-libvirt -->
    <memballoon model="virtio">
      <stats period="10"/>
    </memballoon>
  </devices>
</domain>
